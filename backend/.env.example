# =============================================================================
# Environment Variables — backend/.env.example
# Copy this file to .env and fill in values from your providers.
# NEVER commit .env or .env.production to source control.
# =============================================================================

# --- Application ---
PORT=3000
NODE_ENV=development

# --- Supabase Project ---
# Found in: Supabase Dashboard > Settings > API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Used to verify Supabase-issued JWTs in JwtAuthGuard.
# Found in: Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=<your-jwt-secret>

# --- Database ---
# Direct Postgres connection string.
# Local dev: postgresql://postgres:<password>@localhost:5432/postgres
# Production: use pooler URL from Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/postgres

# --- Redis ---
# Local dev: localhost. Production: Upstash or ElastiCache endpoint.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- AWS S3 (Media Uploads) ---
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
S3_BUCKET=<your-s3-bucket-name>
S3_REGION=us-east-1

# --- Stripe Connect (Payments/Giving) ---
STRIPE_SECRET_KEY=sk_test_<your-stripe-test-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>

# --- Mux (Video Processing) ---
MUX_WEBHOOK_SECRET=<your-mux-webhook-secret>

# --- OneSignal (Push Notifications) ---
ONESIGNAL_APP_ID=<your-onesignal-app-id>
ONESIGNAL_REST_API_KEY=<your-onesignal-rest-api-key>

# --- Super Admins ---
# Comma-separated list of emails that have super admin privileges.
SUPER_ADMIN_EMAILS=admin@yourplatform.com
